{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "stashpad",
  "version": "1.2.0",
  "identifier": "org.stashpad",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run vite:dev",
    "beforeBuildCommand": "npm run vite:build"
  },
  "app": {
    "windows": [
      {
        "title": "Stashpad",
        "width": 800,
        "height": 600,
        "minWidth": 375,
        "minHeight": 450,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "windowEffects": {
          "effects": [
            "blur"
          ],
          "color": [
            24,
            24,
            27,
            200
          ]
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data: blob:; connect-src *; font-src 'self' data:; media-src 'self' asset: https://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.stashpad/**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../assets/stashpad/tauri/icons/32x32.png",
      "../assets/stashpad/tauri/icons/128x128.png",
      "../assets/stashpad/tauri/icons/128x128@2x.png",
      "../assets/stashpad/tauri/icons/icon.icns",
      "../assets/stashpad/tauri/icons/icon.ico"
    ]
  }
}
