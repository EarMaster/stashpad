{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "ui:dev",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "dev"
            ],
            "isBackground": true,
            "problemMatcher": {
                "owner": "typescript",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ],
                "pattern": {
                    "regexp": "^([^\\s].*)\\((\\d+|\\d+,\\d+|\\d+,\\d+,\\d+,\\d+)\\):\\s+(error|warning|info)\\s+(TS\\d+)\\s*:\\s*(.*)$",
                    "file": 1,
                    "location": 2,
                    "severity": 3,
                    "code": 4,
                    "message": 5
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*vite v.*ready in.*$",
                    "endsPattern": "^.*Local:.*http://localhost:.*$"
                }
            }
        },
        {
            "label": "tauri:build-debug",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "tauri",
                "build",
                "--",
                "--debug"
            ],
            "group": "build"
        }
    ]
}