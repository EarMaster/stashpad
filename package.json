{
  "name": "stashpad",
  "version": "1.2.6",
  "description": "The staging area for your AI context.",
  "author": {
    "name": "Nico Wiedemann",
    "email": "nico.wiedemann@gmail.com",
    "url": "https://nico.wiedemann.rocks/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/EarMaster/stashpad.git"
  },
  "license": "AGPL-3.0",
  "keywords": [
    "tauri",
    "svelte",
    "rust",
    "ai",
    "developer-tool",
    "clipboard",
    "productivity"
  ],
  "type": "module",
  "scripts": {
    "sync-version": "node scripts/sync-version.mjs",
    "predev": "npm run sync-version",
    "dev": "tauri dev",
    "vite:dev": "vite",
    "vite:build": "tsc && vite build",
    "prebuild": "npm run sync-version",
    "build": "npm run vite:build && tauri build",
    "vite:preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:icons": "tauri icon --output ./assets/stashpad/tauri/icons --ios-color #d8d8d9 ./assets/stashpad/Icon-Darkmode.svg",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --testPathPattern=\\.test\\.",
    "test:integration": "vitest run --testPathPattern=\\.integration\\."
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10.4.22",
    "happy-dom": "^20.1.0",
    "js-yaml": "^4.1.1",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "svelte": "^5.45.6",
    "tailwindcss": "^4.1.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-deep-link": "^2.4.7",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@thisux/sveltednd": "^0.0.20",
    "@types/dompurify": "^3.0.5",
    "bits-ui": "^2.14.4",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.2",
    "fuzzysort": "^3.1.0",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "jwt-decode": "^4.0.0",
    "lucide-svelte": "^0.556.0",
    "marked": "^17.0.1",
    "marked-highlight": "^2.2.3",
    "svelte-dnd-action": "^0.9.68",
    "svelte-i18n": "^4.0.1",
    "tailwind-merge": "^3.4.0"
  }
}